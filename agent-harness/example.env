# =============================================================================
# Marketing OS — example environment
# Copy to `.env` and edit the marked lines:  cp example.env .env
#
# LEGEND
#   [REQUIRED]  you MUST set this (no working default) — uncomment + fill in
#   [CHANGE]    has a default, but change it for a real Tavily-primary run
#   [DEFAULT]   shown value is the built-in default; uncomment only to override
#
# NOTE: `.env` loads automatically via python-dotenv (PRD decision 9) — just
# `cp example.env .env`, edit, and run. Values already set in your shell / CI
# environment win over `.env`, and a missing `.env` is a no-op.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM provider  (pick ONE provider; set its API key)
# -----------------------------------------------------------------------------

# [DEFAULT] active provider: deepseek | anthropic | openai
# MARKETING_OS_PROVIDER=deepseek

# --- DeepSeek (the default provider) ---
# [REQUIRED] your DeepSeek API key (required when provider=deepseek)
# DEEPSEEK_API_KEY=sk-...
# [DEFAULT] model / base URL
# DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Anthropic (only if MARKETING_OS_PROVIDER=anthropic) ---
# [REQUIRED-if-used] ANTHROPIC_API_KEY=sk-ant-...
# [DEFAULT] ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_BASE_URL=

# --- OpenAI (only if MARKETING_OS_PROVIDER=openai) ---
# [REQUIRED-if-used] OPENAI_API_KEY=sk-...
# [REQUIRED-if-used] OPENAI_MODEL=            # no default — must be set
# OPENAI_BASE_URL=

# [DEFAULT] optional cheaper model for the QA reviewer role
# MARKETING_OS_REVIEWER_MODEL=deepseek-v4-flash


# -----------------------------------------------------------------------------
# Web search  (Tavily primary, Playwright fallback)
# -----------------------------------------------------------------------------

# [CHANGE] web search is OFF by default — set to 1 to enable it for the run
MARKETING_OS_WEB=1

# [REQUIRED] your Tavily API key (primary search/fetch backend).
# If unset, Tavily is skipped with a warning and search falls back to
# Google -> DuckDuckGo scraping.
MARKETING_OS_TAVILY_API_KEY=tvly-REPLACE_ME

# [DEFAULT] backend priority order (first available wins, falls through on
# failure/empty). This is now the built-in default; uncomment only to override.
# MARKETING_OS_WEB_BACKENDS=tavily,google,duckduckgo

# [DEFAULT] Tavily search/extract depth: basic (1 credit) | advanced (2 credits)
# MARKETING_OS_TAVILY_SEARCH_DEPTH=basic


# -----------------------------------------------------------------------------
# Runtime knobs  (all optional — defaults shown)
# -----------------------------------------------------------------------------

# [DEFAULT] repo root; auto-discovered from the nearest .claude/ dir if unset
# MARKETING_OS_ROOT=/Users/zaffere/we-os

# [DEFAULT] tool-call budget per specialist inner loop
# MARKETING_OS_MAX_STEPS=20

# [DEFAULT] revision budget for the per-stage QA loop
# MARKETING_OS_MAX_QA=3

# [DEFAULT] stream CLI progress events (1 on, 0 off)
# MARKETING_OS_STREAM=1

# [DEFAULT] console log level: DEBUG | INFO | WARNING | ERROR
# MARKETING_OS_LOG_LEVEL=INFO

# [DEFAULT] write a per-run JSONL trace under logs/ (1 on, 0 off)
# MARKETING_OS_RUN_LOGS=1

# [DEFAULT] run the QA reviewer in thinking mode (0 off, 1 on)
# MARKETING_OS_REVIEWER_THINKING=0
